{
  "manifest_version": 3,
  "name": "Norix",
  "version": "3.0.0",
  "description": "AI-powered phishing, email scam, SMS fraud, OTP scam & virus detection + Ad Blocker. Works on Gmail, WhatsApp Web, banking sites & everywhere.",
  "incognito": "spanning",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "notifications",
    "history",
    "contextMenus",
    "webNavigation",
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://rdap.org/*",
    "https://ip-api.com/*",
    "https://api.pwnedpasswords.com/*",
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ad_blocker_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "commands": {
    "scan-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Scan current page with Norix"
    },
    "toggle-adblocker": {
      "suggested_key": {
        "default": "Ctrl+Shift+A"
      },
      "description": "Toggle ad blocker on/off"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
