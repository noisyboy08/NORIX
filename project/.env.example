VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GEMINI_API_KEY=
# Copy to `.env` and fill in. Never commit real keys.
# Client-side Vite vars are exposed in the browser bundle — use Supabase Edge Functions for secrets.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_GEMINI_API_KEY=your_gemini_api_key

# Optional: point dashboard/extension at a custom API base (if you add one)
# VITE_API_BASE_URL=
